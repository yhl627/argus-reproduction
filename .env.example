# Argus Reproduction environment template.
# Copy this file to .env and fill in real credentials locally.
# Never commit real API keys.

# ===== LLM / DashScope-compatible API =====
DASHSCOPE_API_KEY=<YOUR_DASHSCOPE_API_KEY>
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Stage-specific model routing. ARGUS_LLM_MODEL is the fallback for legacy paths.
ARGUS_LLM_MODEL=glm-5.2
ARGUS_SEARCHER_MODEL=glm-5.2
ARGUS_VERIFICATION_MODEL=glm-5.2
ARGUS_SUMMARY_MODEL=deepseek-v4-flash
ARGUS_GRAPH_EXTRACTION_MODEL=qwen3.7-plus
ARGUS_GRAPH_COMPACTION_MODEL=qwen3.7-plus
ARGUS_SYNTHESIS_MODEL=qwen3.7-plus
ARGUS_NAVIGATOR_PLANNING_MODEL=glm-5.2
ARGUS_JUDGE_MODEL=deepseek-v4-pro

# ===== Bocha Search =====
BOCHA_API_KEY=<YOUR_BOCHA_API_KEY>
BOCHA_BASE_URL=https://api.bocha.cn/v1

# ===== Jina Reader =====
JINA_API_KEY=<YOUR_JINA_API_KEY>
JINA_READER_BASE_URL=https://r.jina.ai

# ===== Visit Provider =====
# Options: jina_reader or crawl4ai.
ARGUS_VISIT_PROVIDER=jina_reader
ARGUS_VISIT_TIMEOUT=45

# Maximum reader text passed into VISIT extraction, counted with tiktoken cl100k_base.
# Set to 0 only if the selected LLM/backend can safely handle very large prompts.
ARGUS_SEARCHER_VISIT_EXTRACTION_INPUT_MAX_TOKENS=50000

# VISIT extraction output token budget.
ARGUS_SEARCHER_VISIT_EXTRACTION_MAX_TOKENS=4096

# Whether Jina Reader requests should inherit proxy environment variables.
ARGUS_VISIT_TRUST_ENV=true

# Optional crawl4ai browser proxy. Leave empty for direct connection or environment fallback.
ARGUS_CRAWL4AI_PROXY=

# ===== Navigator Budgets =====
ARGUS_MAX_INITIAL_DISPATCH=8
ARGUS_MAX_ROUNDS=8
ARGUS_MAX_SEARCHER_CALLS=64
ARGUS_SEARCH_TOP_K=10
ARGUS_MAX_DISPATCH_PER_ROUND=16

# ===== Concurrency =====
ARGUS_SEARCHER_CONCURRENCY=8

# ===== Searcher Budgets =====
ARGUS_TRAJECTORY_WINDOW_SIZE=12
ARGUS_TRAJECTORY_WINDOW_STRIDE=6
ARGUS_MAX_SEARCHER_STEPS=24

# Thinking is logged when available, but never fed back into later state.
ARGUS_SEARCHER_ENABLE_THINKING=false
ARGUS_NAVIGATOR_ENABLE_THINKING=false
ARGUS_SEARCHER_THINKING_TOKEN_MULTIPLIER=2.0
ARGUS_NAVIGATOR_THINKING_TOKEN_MULTIPLIER=2.0

ARGUS_SEARCHER_ACTION_MAX_TOKENS=4096
ARGUS_SEARCHER_FORCED_ANSWER_MAX_TOKENS=4096

# ===== Navigator LLM Token Budgets =====
ARGUS_NAVIGATOR_INITIAL_QUERY_MAX_TOKENS=4096
ARGUS_NAVIGATOR_GRAPH_EXTRACTION_MAX_TOKENS=16384
ARGUS_NAVIGATOR_VERIFICATION_MAX_TOKENS=16384
ARGUS_NAVIGATOR_COMPACTION_MAX_TOKENS=8192
ARGUS_NAVIGATOR_FOLLOWUP_MAX_TOKENS=8192
ARGUS_NAVIGATOR_SYNTHESIS_MAX_TOKENS=16384

# ===== Retry / JSON Repair =====
ARGUS_RETRY_ATTEMPTS=4
ARGUS_JSON_RETRY_ATTEMPTS=3
ARGUS_JSON_RETRY_TOKEN_STEP=500

# 0 means no project-side cap for JSON retry expansion.
ARGUS_JSON_RETRY_MAX_TOKENS=0
